+        "messages": messages,
+        "mode": "chat",
+        "stream": bool(stream),
+        "fallback_allowed": bool(fallback_allowed),
+    }
+    if max_new_tokens is not None:
+        payload["max_new_tokens"] = max(1, int(max_new_tokens))
